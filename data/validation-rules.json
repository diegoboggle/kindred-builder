        "minDots": 1
      }
    },
    {
      "id": "rule_nosferatu_cannot_take_appearance_merits",
      "scope": "character",
      "origin": "logical",
      "severity": "error",
      "description": "Por la Maldición de clan, los Nosferatu no pueden adquirir Méritos de Aspecto positivos.",
      "source": {
        "kind": "logicalInference",
        "basis": "Los Méritos positivos de Aspecto contradicen la lógica de creación para Nosferatu."
      },
      "when": {
        "clanId": "clan_nosferatu"
      },
      "effect": {
        "type": "forbidTraitCategory",
        "catalog": "advantages",
        "traitType": "merit",
        "category": "Aspecto"
      }
    },
    {
      "id": "rule_no_haven_blocks_haven_traits",
      "scope": "character",
      "origin": "logical",
      "severity": "error",
      "description": "Sin Refugio bloquea Refugio y cualquier rasgo dependiente de Refugio.",
      "source": {
        "kind": "logicalInference",
        "basis": "No puede existir una característica de Refugio si el personaje tiene Sin Refugio."
      },
      "when": {
        "hasTraitId": "flaw_refugio_sin_refugio"
      },
      "effect": {
        "type": "forbidTraitCategory",
        "catalog": "advantages",
        "category": "Refugio",
        "exceptTraitIds": [
          "flaw_refugio_sin_refugio"
        ]
      }
    },
    {
      "id": "rule_haven_traits_require_haven",
      "scope": "character",
      "origin": "logical",
      "severity": "error",
      "description": "Todo rasgo de Refugio distinto de Refugio y Sin Refugio requiere Refugio 1.",
      "source": {
        "kind": "logicalInference",
        "basis": "Los rasgos de Refugio son características de un Refugio existente."
      },
      "when": {
        "hasTraitCategory": "Refugio",
        "exceptTraitIds": [
          "merit_refugio",
          "flaw_refugio_sin_refugio"
        ]
      },
      "effect": {
        "type": "requireTrait",
        "catalog": "advantages",
        "traitId": "merit_refugio",
        "minDots": 1
      }
    },
    {
      "id": "rule_domain_personal_backgrounds_spend_domain_pool",
      "scope": "domain",
      "origin": "logical",
      "severity": "error",
      "description": "Los trasfondos de Dominio personal sólo pueden comprarse con el pool de Dominio personal. Ese pool puede incluir puntos base, puntos concedidos, defectos de Dominio y contribuciones actuales desde Ventajas individuales.",
      "source": {
        "kind": "projectAdaptation",
        "basis": "La crónica usa Dominio personal en lugar de coterías reales."
      },
      "effect": {
        "type": "spendingPoolRestriction",
        "catalog": "domain",
        "traitTypes": [
          "domainBackground",
          "domainBackgroundFlaw",
          "domainTrait"
        ],
        "allowedPool": "domain",
        "allowedPoolComponents": [
          "domain.pool.baseDots",
          "domain.pool.contributedAdvantageDots",
          "domain.pool.flawDots",
          "domain.pool.grantedDots"
        ]
      }
    },
    {
      "id": "rule_advantage_points_reallocatable_to_domain_during_creation",
      "scope": "domain",
      "origin": "logical",
      "severity": "error",
      "description": "Los puntos de Ventajas individuales pueden moverse hacia o desde Dominio personal durante la creación. Mientras estén asignados a Dominio, deben descontarse del presupuesto normal de Ventajas.",
      "source": {
        "kind": "projectAdaptation",
        "basis": "La crónica usa Dominio personal; se permite planificación flexible antes de finalizar el personaje sin duplicar puntos."
      },
      "effect": {
        "type": "advantageToDomainContribution",
        "fromPool": "advantages.budget.totalMeritDots",
        "trackingField": "advantages.budget.contributedToDomainDots",
        "toPool": "domain.pool.contributedAdvantageDots",
        "contributionList": "domain.contributions",
        "source": "characterAdvantages",
        "sourceBudget": "advantages.meritDots",
        "reversibleDuringCreation": true,
        "locksWhen": "character.finalized"
      }
    },
    {
      "id": "rule_domain_native_points_cannot_fund_character_advantages",
      "scope": "domain",
      "origin": "logical",
      "severity": "error",
      "description": "Los puntos nativos de Dominio personal no pueden moverse al presupuesto de Ventajas ni comprar Ventajas individuales.",
      "source": {
        "kind": "projectAdaptation",
        "basis": "Dominio personal adapta una reserva separada; sólo las contribuciones desde Ventajas son reversibles durante la creación."
      },
      "effect": {
        "type": "forbidDomainToAdvantageContribution",
        "fromPools": [
          "domain.pool.baseDots",
          "domain.pool.flawDots",
          "domain.pool.grantedDots"
        ],
        "forbiddenTargetPools": [
          "advantages.budget.totalMeritDots",
          "advantages.budget.availableMeritDots",
          "advantages.budget.spentMeritDots"
        ],
        "allowedTargetPool": "domain.pool"
      }
    },
    {
      "id": "rule_domain_no_haven_blocks_domain_haven_traits",
      "scope": "domain",
      "origin": "logical",
      "severity": "error",
      "description": "Sin Refugio de Dominio personal bloquea Refugio de Dominio personal y sus defectos asociados.",
      "source": {
        "kind": "projectAdaptation",
        "basis": "Adaptación individual de la lógica de Refugio."
      },
      "when": {
        "hasDomainTraitId": "domain_background_flaw_refugio_sin_refugio"
      },
      "effect": {
        "type": "forbidDomainTrait",
        "catalog": "domain",
        "traitIds": [
          "domain_background_refugio",
          "domain_background_flaw_refugio_espeluznante",
          "domain_background_flaw_refugio_embrujado",
          "domain_background_flaw_refugio_comprometido"
        ],
        "exceptTraitIds": [
          "domain_background_flaw_refugio_sin_refugio"
        ]
      }
    },
    {
      "id": "rule_domain_haven_flaws_require_domain_haven",
      "scope": "domain",
      "origin": "logical",
      "severity": "error",
      "description": "Los defectos de Refugio adaptados al Dominio personal requieren Refugio de Dominio personal.",
      "source": {
        "kind": "projectAdaptation",
        "basis": "Espeluznante, Embrujado y Comprometido son rasgos de un Refugio existente."
      },
      "when": {
        "hasAnyDomainTraitId": [
          "domain_background_flaw_refugio_espeluznante",
          "domain_background_flaw_refugio_embrujado",
          "domain_background_flaw_refugio_comprometido"
        ]
      },
      "effect": {
        "type": "requireDomainTrait",
        "catalog": "domain",
        "traitId": "domain_background_refugio",
        "minDots": 1
      }
    },
    {
      "id": "rule_domain_obvious_predator_blocks_domain_herd",
      "scope": "domain",
      "origin": "logical",
      "severity": "error",
      "description": "Depredador Manifiesto también bloquea Rebaño comprado como trasfondo de Dominio personal.",
      "source": {
        "kind": "projectAdaptation",
        "basis": "Extiende la restricción de Rebaño al modo de Dominio personal."
      },
      "when": {
        "hasTraitId": "flaw_rebano_depredador_manifiesto"
      },
      "effect": {
        "type": "forbidDomainTrait",
        "catalog": "domain",
        "traitId": "domain_background_rebano"
      }
    },
    {
      "id": "rule_domain_haven_incompatible_with_domain_no_haven",
      "scope": "domain",
      "origin": "logical",
      "severity": "error",
      "description": "Refugio de Dominio personal y Sin Refugio de Dominio personal son incompatibles.",
      "source": {
        "kind": "projectAdaptation",
        "basis": "Adaptación individual de la incompatibilidad entre Refugio y Sin Refugio."
      },
      "effect": {
        "type": "incompatibleTraitPair",
        "catalog": "domain",
        "traitIds": [
          "domain_background_refugio",
          "domain_background_flaw_refugio_sin_refugio"
        ]
      }
    }
  ]
}
