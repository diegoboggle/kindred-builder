{
  "$schema": "../schemas/validation-rules.schema.json",
  "schemaVersion": "validation-rules-v1",
  "sourceOfTruth": {
    "creatorData": "data/creator-data.json",
    "disciplineCatalog": "data/disciplinas_v5_catalogo.json",
    "domainPolicy": "data/creator-data.json#/domainCatalogModel"
  },
  "policy": {
    "defaultSeverity": "error",
    "allowedOrigins": [
      "official",
      "logical"
    ],
    "allRulesAreBlocking": true,
    "notes": "Las reglas son inflexibles: toda infracción produce error bloqueante. Los puntos de Ventajas individuales pueden reasignarse hacia o desde Dominio personal durante la creación; mientras estén asignados a Dominio se descuentan del presupuesto individual. Los puntos nativos de Dominio personal no pueden salir de Dominio ni comprar Ventajas individuales."
  },
  "effectTypes": [
    "forbidTrait",
    "forbidTraitCategory",
    "requireTrait",
    "incompatibleTraitPair",
    "skillMaximum",
    "disciplineMaximum",
    "requireDiscipline",
    "requireDomainTrait",
    "forbidDomainTrait",
    "forbidDomainTraitCategory",
    "requireDomainTraitForCategory",
    "spendingPoolRestriction",
    "advantageToDomainContribution",
    "forbidDomainToAdvantageContribution"
  ],
  "rules": [
