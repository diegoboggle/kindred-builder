            "current": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "humanity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "bloodPotency": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "budgets": {
          "type": "object",
