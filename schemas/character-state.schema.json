                "contributedToDomainDots": {
                  "type": "integer",
                  "minimum": 0
                },
                "availableMeritDots": {
                  "type": "integer",
                  "minimum": 0
                },
                "totalFlawDots": {
                  "type": "integer",
                  "minimum": 0
                },
                "spentFlawDots": {
                  "type": "integer",
                  "minimum": 0
                },
                "receivedFromDomainDots": {
                  "const": 0
