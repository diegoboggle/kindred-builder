{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://santiago-nocturno.local/schemas/character-state.schema.json",
  "title": "Character Creator State - Exportable Complete Character (Strict)",
  "type": "object",
  "description": "Estado de personaje completo y exportable. Los borradores internos de UI no deben exportarse con este schema. Los objetos estructurados rechazan propiedades adicionales; sólo los mapas dinámicos documentados aceptan claves variables.",
  "required": [
    "schemaVersion",
    "exportStatus",
    "creationStatus",
    "metadata",
    "discordId",
    "basics",
    "clan",
    "generation",
    "sire",
    "predator",
    "attrSequence",
    "attributes",
    "skillSequence",
    "skills",
    "freeSpecialtySkill",
    "freeSpecialtyName",
    "specialties",
    "disciplines",
    "advantages",
    "domain",
    "convictions",
    "touchstones",
    "profile",
    "derived",
    "creationProgress"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "minLength": 1
    },
    "exportStatus": {
      "const": "complete"
    },
    "creationStatus": {
      "const": "finalized"
    },
    "metadata": {
      "type": "object",
      "required": [
        "characterId",
        "createdAt",
        "updatedAt",
        "appVersion"
      ],
      "properties": {
        "characterId": {
          "type": "string",
          "pattern": "^character_[a-zA-Z0-9_-]+$"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "appVersion": {
          "type": "string",
          "minLength": 1
        },
        "exportedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "discordId": {
      "type": "string",
      "pattern": "^[0-9]{17,20}$"
    },
    "basics": {
      "type": "object",
      "required": [
        "name",
        "concept",
        "ambition",
        "desire"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "concept": {
          "type": "string",
          "minLength": 1
        },
        "ambition": {
          "type": "string",
          "minLength": 1
        },
        "desire": {
          "type": "string",
          "minLength": 1
        },
        "chronicle": {
          "type": "string"
        },
        "player": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "clan": {
      "type": "object",
      "required": [
        "clanId"
      ],
      "properties": {
        "clanId": {
          "type": "string",
          "pattern": "^clan_[a-z0-9_]+$"
        },
        "lineageId": {
          "type": "string",
          "pattern": "^lineage_[a-z0-9_]+$"
        },
        "baneNotes": {
          "type": "string"
        },
        "compulsionNotes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "generation": {
      "type": "object",
      "required": [
        "generationId"
      ],
      "properties": {
        "generationId": {
          "type": "string",
          "pattern": "^generation_[a-z0-9_]+$"
        },
        "bloodPotencyBase": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        }
      },
      "additionalProperties": false
    },
    "sire": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "known",
            "unknown",
            "none",
            "unrecorded"
          ]
        },
        "sireId": {
          "type": "string",
          "pattern": "^character_[a-zA-Z0-9_-]+$"
        },
        "name": {
          "type": "string"
        },
        "clanId": {
          "type": "string",
          "pattern": "^clan_[a-z0-9_]+$"
        },
        "relationship": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "predator": {
      "type": "object",
      "required": [
        "predatorId",
        "selectedDisciplineId",
        "selectedSpecialty"
      ],
      "properties": {
        "predatorId": {
          "type": "string",
          "pattern": "^predator_[a-z0-9_]+$"
        },
        "selectedDisciplineId": {
          "type": "string",
          "minLength": 1
        },
        "selectedSpecialty": {
          "type": "object",
          "required": [
            "skill",
            "name"
          ],
          "properties": {
            "skill": {
              "type": "string",
              "enum": [
                "Academicismo",
                "Armas de Fuego",
                "Artesanía",
                "Atletismo",
                "Callejeo",
                "Ciencias",
                "Conducir",
                "Consciencia",
                "Etiqueta",
                "Finanzas",
                "Interpretación",
                "Intimidación",
                "Investigación",
                "Latrocinio",
                "Liderazgo",
                "Medicina",
                "Ocultismo",
                "Pelea",
                "Pelea con Armas",
                "Perspicacia",
                "Persuasión",
                "Política",
                "Sigilo",
                "Subterfugio",
                "Supervivencia",
                "Tecnología",
                "Trato con Animales"
              ]
            },
            "name": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "automaticAwardsApplied": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "attrSequence": {
      "type": "array",
      "description": "Orden de los 5 atributos modificados durante la creación. Posición 1 = 4, posición 2 = 1, posiciones 3-5 = 3; los no elegidos quedan en 2.",
      "items": {
        "type": "string",
        "enum": [
          "Fuerza",
          "Destreza",
          "Resistencia",
          "Carisma",
          "Manipulación",
          "Compostura",
          "Inteligencia",
          "Astucia",
          "Resolución"
        ]
      },
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true
    },
    "attributes": {
      "type": "object",
      "description": "Mapa final de atributos. En creación inicial debe cumplir la distribución 4/3/3/3/2/2/2/2/1.",
      "required": [
        "Fuerza",
        "Destreza",
        "Resistencia",
        "Carisma",
        "Manipulación",
        "Compostura",
        "Inteligencia",
        "Astucia",
        "Resolución"
      ],
      "properties": {
        "Fuerza": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "Destreza": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "Resistencia": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "Carisma": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "Manipulación": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "Compostura": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "Inteligencia": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "Astucia": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "Resolución": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        }
      },
      "additionalProperties": false
    },
    "skillSequence": {
      "type": "array",
      "description": "Orden de las 10 habilidades modificadas durante la creación. Posición 1 = 4, posiciones 2-4 = 3, posiciones 5-7 = 2, posiciones 8-10 = 1; las no elegidas quedan en 0.",
      "items": {
        "type": "string",
        "enum": [
          "Academicismo",
          "Armas de Fuego",
          "Artesanía",
          "Atletismo",
          "Callejeo",
          "Ciencias",
          "Conducir",
          "Consciencia",
          "Etiqueta",
          "Finanzas",
          "Interpretación",
          "Intimidación",
          "Investigación",
          "Latrocinio",
          "Liderazgo",
          "Medicina",
          "Ocultismo",
          "Pelea",
          "Pelea con Armas",
          "Perspicacia",
          "Persuasión",
          "Política",
          "Sigilo",
          "Subterfugio",
          "Supervivencia",
          "Tecnología",
          "Trato con Animales"
        ]
      },
      "minItems": 10,
      "maxItems": 10,
      "uniqueItems": true
    },
    "skills": {
      "type": "object",
      "description": "Mapa final de habilidades. En creación inicial debe cumplir la distribución 4/3/3/3/2/2/2/1/1/1 y el resto en 0.",
      "required": [
        "Academicismo",
        "Armas de Fuego",
        "Artesanía",
        "Atletismo",
        "Callejeo",
        "Ciencias",
        "Conducir",
        "Consciencia",
        "Etiqueta",
        "Finanzas",
        "Interpretación",
        "Intimidación",
        "Investigación",
        "Latrocinio",
        "Liderazgo",
        "Medicina",
        "Ocultismo",
        "Pelea",
        "Pelea con Armas",
        "Perspicacia",
        "Persuasión",
        "Política",
        "Sigilo",
        "Subterfugio",
        "Supervivencia",
        "Tecnología",
        "Trato con Animales"
      ],
      "properties": {
        "Academicismo": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Armas de Fuego": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Artesanía": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Atletismo": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Callejeo": {
          "type": "integer",
