          "maximum": 4
        },
        "Conducir": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Consciencia": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Etiqueta": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Finanzas": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Interpretación": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Intimidación": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Investigación": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Latrocinio": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Liderazgo": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Medicina": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Ocultismo": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Pelea": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Pelea con Armas": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Perspicacia": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Persuasión": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Política": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Sigilo": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Subterfugio": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Supervivencia": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Tecnología": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "Trato con Animales": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        }
      },
      "additionalProperties": false
    },
    "freeSpecialtySkill": {
      "description": "Habilidad de la especialidad gratuita obligatoria. Debe estar entrenada y coincidir con una entrada de specialties con source='free'.",
      "type": "string",
      "enum": [
        "Academicismo",
        "Armas de Fuego",
        "Artesanía",
        "Atletismo",
        "Callejeo",
        "Ciencias",
        "Conducir",
        "Consciencia",
        "Etiqueta",
        "Finanzas",
        "Interpretación",
        "Intimidación",
        "Investigación",
        "Latrocinio",
        "Liderazgo",
        "Medicina",
        "Ocultismo",
        "Pelea",
        "Pelea con Armas",
        "Perspicacia",
        "Persuasión",
        "Política",
        "Sigilo",
        "Subterfugio",
        "Supervivencia",
        "Tecnología",
        "Trato con Animales"
      ]
    },
    "freeSpecialtyName": {
      "type": "string",
      "minLength": 1,
      "description": "Nombre de la especialidad gratuita obligatoria. Debe coincidir con una entrada de specialties con source='free'."
    },
    "specialties": {
      "type": "array",
      "description": "Especialidades manuales y automáticas con origen explícito. Sólo pueden apuntar a habilidades entrenadas; el total por habilidad no puede superar sus puntos.",
      "items": {
        "type": "object",
        "required": [
          "skill",
          "name",
          "source"
        ],
        "properties": {
          "skill": {
            "type": "string",
            "enum": [
              "Academicismo",
              "Armas de Fuego",
              "Artesanía",
              "Atletismo",
              "Callejeo",
              "Ciencias",
              "Conducir",
              "Consciencia",
              "Etiqueta",
              "Finanzas",
              "Interpretación",
              "Intimidación",
              "Investigación",
              "Latrocinio",
              "Liderazgo",
              "Medicina",
              "Ocultismo",
              "Pelea",
              "Pelea con Armas",
              "Perspicacia",
              "Persuasión",
              "Política",
              "Sigilo",
              "Subterfugio",
              "Supervivencia",
              "Tecnología",
              "Trato con Animales"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "enum": [
              "free",
              "predator",
              "advantage",
              "manual",
              "other"
            ]
          },
          "sourceId": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false,
        "description": "Una especialidad. El campo source es obligatorio para distinguir especialidad gratuita, depredador, ventaja, manual u otro origen."
      }
    },
    "disciplines": {
      "type": "object",
      "required": [
        "ratings",
        "powers"
      ],
      "properties": {
        "ratings": {
          "type": "object",
          "description": "Mapa de disciplineId a puntos.",
          "propertyNames": {
            "pattern": "^[a-z0-9_]+$"
          },
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "maximum": 5
          }
        },
        "powers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "recordId"
            ],
            "properties": {
              "recordId": {
                "type": "string",
                "pattern": "^[a-z0-9_]+$"
              },
              "disciplineId": {
                "type": "string",
                "pattern": "^[a-z0-9_]+$"
              },
              "source": {
                "type": "string",
                "enum": [
                  "creation",
                  "predator",
                  "experience",
                  "other"
                ]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "advantages": {
      "type": "object",
      "required": [
        "merits",
        "flaws",
        "budget"
      ],
      "properties": {
        "merits": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "traitId",
              "dots",
              "source"
            ],
            "properties": {
              "traitId": {
                "type": "string",
                "pattern": "^(merit|flaw)_[a-z0-9_]+$"
              },
              "dots": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "source": {
                "type": "string",
                "enum": [
                  "manual",
                  "predator",
                  "advantage",
                  "domain",
                  "other"
                ]
              },
              "sourceId": {
                "type": "string",
                "minLength": 1
              },
              "detail": {
                "type": "string"
              },
              "detailDefault": {
                "type": "string"
              },
              "purchaseScope": {
                "type": "string",
                "enum": [
                  "character",
                  "domain"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "flaws": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "traitId",
              "dots",
              "source"
            ],
            "properties": {
              "traitId": {
                "type": "string",
                "pattern": "^(merit|flaw)_[a-z0-9_]+$"
              },
              "dots": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "source": {
                "type": "string",
                "enum": [
                  "manual",
                  "predator",
                  "advantage",
                  "domain",
                  "other"
                ]
              },
              "sourceId": {
                "type": "string",
                "minLength": 1
              },
              "detail": {
                "type": "string"
              },
              "detailDefault": {
                "type": "string"
              },
              "purchaseScope": {
                "type": "string",
                "enum": [
                  "character",
                  "domain"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "budget": {
          "type": "object",
          "required": [
            "totalMeritDots",
            "spentMeritDots",
            "contributedToDomainDots",
            "availableMeritDots"
          ],
          "properties": {
            "totalMeritDots": {
              "type": "integer",
              "minimum": 0
            },
            "spentMeritDots": {
              "type": "integer",
              "minimum": 0
            },
            "contributedToDomainDots": {
              "type": "integer",
              "minimum": 0
            },
            "availableMeritDots": {
              "type": "integer",
              "minimum": 0
            },
            "totalFlawDots": {
              "type": "integer",
              "minimum": 0
            },
            "spentFlawDots": {
              "type": "integer",
              "minimum": 0
            },
            "receivedFromDomainDots": {
              "const": 0
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "domain": {
      "type": "object",
      "required": [
        "enabled",
        "pool",
        "traits",
        "merits",
        "flaws",
        "contributions",
        "backgrounds"
      ],
      "properties": {
        "enabled": {
          "const": true
        },
        "pool": {
          "type": "object",
          "required": [
            "baseDots",
            "contributedAdvantageDots",
            "flawDots",
            "grantedDots",
            "spentDots"
          ],
          "properties": {
            "baseDots": {
              "type": "integer",
              "minimum": 1
            },
            "contributedAdvantageDots": {
              "type": "integer",
              "minimum": 0
            },
            "flawDots": {
              "type": "integer",
              "minimum": 0
            },
            "grantedDots": {
              "type": "integer",
              "minimum": 0
            },
            "spentDots": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "traits": {
          "type": "object",
          "required": [
            "chasse",
            "lien",
            "portillon"
          ],
          "properties": {
            "chasse": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            },
            "lien": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            },
            "portillon": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            }
          },
          "additionalProperties": false
        },
        "merits": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "domainTraitId",
              "dots",
              "purchaseScope"
            ],
            "properties": {
              "domainTraitId": {
                "type": "string",
                "pattern": "^domain_[a-z0-9_]+$"
              },
              "sourceTraitId": {
                "type": "string",
                "pattern": "^(merit|flaw)_[a-z0-9_]+$"
              },
              "dots": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "purchaseScope": {
                "const": "domain"
              },
              "source": {
                "type": "string",
                "enum": [
                  "manual",
                  "predator",
                  "contribution",
                  "flaw",
                  "other"
                ]
              },
              "sourceId": {
                "type": "string",
                "minLength": 1
              },
              "detail": {
                "type": "string"
              },
              "note": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "flaws": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "domainTraitId",
              "dots",
              "purchaseScope"
            ],
            "properties": {
              "domainTraitId": {
                "type": "string",
                "pattern": "^domain_[a-z0-9_]+$"
              },
              "sourceTraitId": {
                "type": "string",
                "pattern": "^(merit|flaw)_[a-z0-9_]+$"
              },
              "dots": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "purchaseScope": {
                "const": "domain"
              },
              "source": {
                "type": "string",
                "enum": [
                  "manual",
                  "predator",
                  "contribution",
                  "flaw",
                  "other"
                ]
              },
              "sourceId": {
                "type": "string",
                "minLength": 1
              },
              "detail": {
                "type": "string"
              },
              "note": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "backgrounds": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "domainTraitId",
              "dots",
              "purchaseScope"
            ],
            "properties": {
              "domainTraitId": {
                "type": "string",
                "pattern": "^domain_[a-z0-9_]+$"
              },
              "sourceTraitId": {
                "type": "string",
                "pattern": "^(merit|flaw)_[a-z0-9_]+$"
              },
              "dots": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "purchaseScope": {
                "const": "domain"
              },
              "source": {
                "type": "string",
                "enum": [
                  "manual",
                  "predator",
                  "contribution",
                  "flaw",
                  "other"
                ]
              },
              "sourceId": {
                "type": "string",
                "minLength": 1
              },
              "detail": {
                "type": "string"
              },
              "note": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "contributions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "source",
              "sourceBudget",
              "dots",
              "reason"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^domain_contribution_[a-z0-9_]+$"
              },
              "source": {
                "const": "characterAdvantages"
              },
              "sourceBudget": {
                "const": "advantages.meritDots"
              },
              "dots": {
                "type": "integer",
                "minimum": 1
              },
              "reason": {
                "type": "string"
              },
              "targetPool": {
                "const": "domain.pool.contributedAdvantageDots"
              },
              "reversibleDuringCreation": {
                "const": true
              },
              "lockedAfterFinalization": {
                "const": true
              },
              "allocationStatus": {
                "enum": [
                  "planned",
                  "active",
                  "committed"
                ]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "convictions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": [
          "id",
          "text"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^conviction_[a-zA-Z0-9_-]+$"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "touchstoneId": {
            "type": "string",
            "pattern": "^touchstone_[a-zA-Z0-9_-]+$"
          }
        },
        "additionalProperties": false
      }
    },
    "touchstones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "relationship",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^touchstone_[a-zA-Z0-9_-]+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "relationship": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "linkedConvictionId": {
            "type": "string",
            "pattern": "^conviction_[a-zA-Z0-9_-]+$"
          }
        },
        "additionalProperties": false
      }
    },
    "profile": {
      "type": "object",
      "required": [
